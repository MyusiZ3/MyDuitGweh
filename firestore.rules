rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return request.auth != null && (getUserData().role == 'admin' || getUserData().role == 'superadmin');
    }

    function isSuperAdmin() {
      return request.auth != null && getUserData().role == 'superadmin';
    }

    // Allow Admins to query collection groups (Live Insights)
    match /{path=**}/wallets/{walletId} {
      allow read: if isAdmin() || (request.auth != null && resource.data.members.hasAny([request.auth.uid]));
    }

    match /app_config/global {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /app_config/global/history/{historyId} {
      allow read: if request.auth != null;
      allow create, update: if isAdmin();
      allow delete: if isSuperAdmin();
    }

    match /broadcasts/{broadcastId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow read: if request.auth != null; 
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && (request.auth.uid == userId || isSuperAdmin());
      allow delete: if isSuperAdmin();
      
      match /notifications/{notificationId} {
        allow read, update, delete: if request.auth != null && (request.auth.uid == userId || isAdmin());
        allow create: if request.auth != null;
      }
    }

    match /wallets/{walletId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.owner || 
        request.auth.uid in resource.data.members || 
        isAdmin()
      );
      allow delete: if request.auth != null && (request.auth.uid == resource.data.owner || isAdmin());

      match /{allSubcollections=**} {
        allow read, write: if request.auth != null;
      }
    }

    match /transactions/{transactionId} {
      allow read, write, delete: if request.auth != null;
    }

  }
}