rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return request.auth != null && (getRole() == 'admin' || getRole() == 'superadmin');
    }

    function isSuperAdmin() {
      return request.auth != null && getRole() == 'superadmin';
    }

    function canWriteTransaction() {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return !('lastTransactionAt' in userDoc.data) || 
             (request.time.toMillis() - userDoc.data.lastTransactionAt.toMillis() >= 1000);
    }

    // Allow Admins to query collection groups (Live Insights)
    match /{path=**}/wallets/{walletId} {
      allow read: if isAdmin() || (request.auth != null && resource.data.members.hasAny([request.auth.uid]));
    }

    match /app_config/notification_listener {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /app_config/global {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /app_config/survey {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /user_feedbacks/{feedbackId} {
      allow read: if isAdmin();
      allow create: if request.auth != null;
      allow update, delete: if isSuperAdmin();
    }

    match /app_settings/ai_config {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /app_config/global/history/{historyId} {
      allow read: if request.auth != null;
      allow create, update: if isAdmin();
      allow delete: if isSuperAdmin();
    }

    match /broadcasts/{broadcastId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow read: if request.auth != null; 
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow delete: if isSuperAdmin();
      
      match /notifications/{notificationId} {
        allow read, update, delete: if request.auth != null && (request.auth.uid == userId || isAdmin());
        allow create: if request.auth != null;
      }
      
      // Capture Notif System
      match /captured_notifications/{notifId} {
        allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
        allow write: if request.auth != null && (request.auth.uid == userId || isAdmin());
      }

      match /notif_config/{document=**} {
        allow read, write: if request.auth != null && (request.auth.uid == userId || isAdmin());
      }
    }

    match /wallets/{walletId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.owner || 
        request.auth.uid in resource.data.members || 
        isAdmin()
      );
      allow delete: if request.auth != null && (request.auth.uid == resource.data.owner || isAdmin());

      match /{allSubcollections=**} {
        allow read, write: if request.auth != null;
      }
    }

    match /transactions/{transactionId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && 
                    request.resource.data.createdBy == request.auth.uid &&
                    canWriteTransaction();
      allow update, delete: if request.auth != null && (resource.data.createdBy == request.auth.uid || isAdmin());
    }

  }
}