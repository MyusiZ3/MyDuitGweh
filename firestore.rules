rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Koleksi Users (Aman) & Sub-koleksi Notifikasi
    match /users/{userId} {
      // Izinkan baca kalau login
      allow read: if request.auth != null; 
      // Izinkan tulis jika dia pemilik akun
      allow write: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.uid == userId;
      
      // SUB-KOLEKSI NOTIFIKASI ADA DI SINI 
      match /notifications/{notificationId} {
        allow read, update, delete: if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null;
      }
    }

    // 2. Koleksi Wallets (Sudah Diperbaiki untuk Gabung Code)
    match /wallets/{walletId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.owner || 
        request.auth.uid in resource.data.members || 
        request.auth.uid in request.resource.data.members
      );
      
      allow delete: if request.auth != null && request.auth.uid == resource.data.owner;

      // SUB-KOLEKSI CHAT MESSAGES
      match /messages/{messageId} {
        allow read, create: if request.auth != null;
        allow delete: if request.auth != null && request.auth.uid == resource.data.senderUid;
      }
    }

    // 3. Koleksi Transactions (Sudah Aman)
    match /transactions/{transactionId} {
      // Pastikan siapa saja yang login boleh tulis transaksi
      allow read, write, delete: if request.auth != null;
    }

  }
}
