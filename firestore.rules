rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Koleksi Users (Aman) & Sub-koleksi Notifikasi
    match /users/{userId} {
      // Izinkan baca kalau login
      allow read: if request.auth != null; 
      // Izinkan tulis jika dia pemilik akun
      allow write: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.uid == userId;
      
      // SUB-KOLEKSI NOTIFIKASI ADA DI SINI 
      match /notifications/{notificationId} {
        allow read, update, delete: if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null;
      }
    }

    // 2. Koleksi Wallets (Sudah Diperbaiki untuk Gabung Code)
    match /wallets/{walletId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.owner || 
        request.auth.uid in resource.data.members || 
        request.auth.uid in request.resource.data.members
      );
      
      allow delete: if request.auth != null && request.auth.uid == resource.data.owner;

      // SUB-KOLEKSI CHAT MESSAGES
      match /messages/{messageId} {
        allow read, create: if request.auth != null;
        allow update: if request.auth != null && request.auth.uid == resource.data.senderUid;
        allow delete: if request.auth != null && request.auth.uid == resource.data.senderUid;
      }

      // SUB-KOLEKSI READ RECEIPTS
      match /readReceipts/{uid} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // 3. Koleksi Transactions (Sangat Aman)
    match /transactions/{transactionId} {
      // Izinkan baca & hapus jika user log in dan termaktub sebagai member di dompet terkait
      allow read, delete: if request.auth != null && (request.auth.uid in get(/databases/$(database)/documents/wallets/$(resource.data.walletId)).data.members);
      // Izinkan tulis/edit jika user log in dan termaktub sebagai member di dompet yang dituju
      allow create, update: if request.auth != null && (request.auth.uid in get(/databases/$(database)/documents/wallets/$(request.resource.data.walletId)).data.members);
    }

  }
}
